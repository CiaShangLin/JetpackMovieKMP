--swiftversion 5.10
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--commas inline
--semicolons never
--trimwhitespace always
--insertlines enabled
--stripunusedargs closure-only
--self remove
--exclude iosApp.xcodeproj,Assets.xcassets,"Preview Content",build,.gradle
